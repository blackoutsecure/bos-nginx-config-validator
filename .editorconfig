root = true

# Repo-specific overrides live OUTSIDE the hub-managed marker block
# below. EditorConfig is last-match-wins, so any [*.sh]-style override
# put here will take effect over the hub's [*] / [Makefile] defaults
# defined inside the marker block.

[*.sh]
indent_size = 4

# >>> bos-automation-hub:common >>>
# Managed by https://github.com/blackoutsecure/bos-automation-hub — do not edit between markers.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
# <<< bos-automation-hub:common <<<
