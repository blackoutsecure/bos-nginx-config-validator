# Normalize line endings to LF for all text files.
* text=auto eol=lf

*.sh           text eol=lf
*.md           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.json         text eol=lf
*.toml         text eol=lf
*.conf         text eol=lf
*.template     text eol=lf
*.txt          text eol=lf
LICENSE        text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
.editorconfig  text eol=lf

# Binary files — skip line-ending conversion.
*.png  binary
*.jpg  binary
*.gif  binary
*.webp binary
*.ico  binary
*.gz   binary
*.zip  binary
*.tar  binary
*.tgz  binary

